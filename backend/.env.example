# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/superadmin_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# DevOTP (development/testing)
DEVOTP_API_KEY=your_devotp_key_here
DEVOTP_BASE_URL=https://api.devotp.com

# SendGrid (production email OTP)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (production SMS OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
