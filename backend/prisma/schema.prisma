generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id                    String   @id @default(uuid())
  full_name             String
  date_of_birth         DateTime
  primary_email         String   @unique
  primary_phone         String   @unique
  alternative_email     String?
  alternative_phone     String?
  password_hash         String
  user_id               String   @unique
  totp_secret           String?
  recovery_code_hash    String?
  security_codes        Json     @default("[]")
  selfie_image_path     String?
  govt_id_type          String?
  govt_id_hash          String?
  security_question_1   String?
  answer_1_hash         String?
  security_question_2   String?
  answer_2_hash         String?
  security_question_3   String?
  answer_3_hash         String?
  approver_name         String?
  approver_designation  String?
  approver_email        String?
  approver_phone        String?
  declarations_accepted Json?
  is_active             Boolean  @default(false)
  signup_completed      Boolean  @default(false)
  is_locked             Boolean  @default(false)
  lock_expires_at       DateTime?
  failed_primary_otp    Int      @default(0)
  failed_alt_otp        Int      @default(0)
  signin_log            Json     @default("[]")
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  sessions          Session[]
  approver_sessions ApproverSession[]
}

model OTPStore {
  id         String   @id @default(uuid())
  identifier String
  otp_hash   String
  type       String
  expires_at DateTime
  used       Boolean  @default(false)
  attempts   Int      @default(0)
  created_at DateTime @default(now())

  @@index([identifier, type])
  @@index([expires_at])
}

model ApproverSession {
  id           String   @id @default(uuid())
  admin_id     String
  code_hash    String
  expires_at   DateTime
  used         Boolean  @default(false)
  created_at   DateTime @default(now())

  admin SuperAdmin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
}

model Session {
  id            String   @id @default(uuid())
  super_admin_id String
  refresh_token String   @unique
  access_token  String?
  expires_at    DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  super_admin SuperAdmin @relation(fields: [super_admin_id], references: [id], onDelete: Cascade)

  @@index([super_admin_id])
}

model SignupSession {
  id              String   @id @default(uuid())
  session_id      String   @unique
  current_step    Int      @default(1)
  completed_steps Int[]    @default([])
  draft_data      Json     @default("{}")
  expires_at      DateTime
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model SigninSession {
  id              String   @id @default(uuid())
  session_id      String   @unique
  admin_id        String?
  current_step    Int      @default(1)
  password_verified Boolean @default(false)
  draft_data      Json     @default("{}")
  expires_at      DateTime
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model PlatformAdmin {
  id                      String    @id @default(uuid())
  full_name               String
  date_of_birth           DateTime
  primary_email           String    @unique
  primary_phone           String    @unique
  alternative_email       String?
  alternative_phone       String?
  password_hash           String
  user_id                 String?   @unique
  totp_secret             String?
  recovery_code_hash      String?
  onboarding_completed    Boolean   @default(false)
  is_active               Boolean   @default(true)
  is_locked               Boolean   @default(false)
  lock_expires_at         DateTime?
  failed_primary_otp      Int       @default(0)
  failed_alt_otp          Int       @default(0)
  magic_link_token_hash   String?
  magic_link_expires_at   DateTime?
  created_by_super_admin  String?
  signin_log              Json      @default("[]")
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  sessions           PlatformAdminSession[]
  signin_sessions    PlatformAdminSigninSession[]
  approval_requests  PlatformAdminApprovalRequest[]
}

model PlatformAdminSession {
  id                String   @id @default(uuid())
  platform_admin_id String
  refresh_token     String   @unique
  access_token      String?
  expires_at        DateTime
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  platform_admin PlatformAdmin @relation(fields: [platform_admin_id], references: [id], onDelete: Cascade)

  @@index([platform_admin_id])
}

model PlatformAdminSigninSession {
  id                String   @id @default(uuid())
  session_id        String   @unique
  platform_admin_id String?
  password_verified Boolean  @default(false)
  draft_data        Json     @default("{}")
  expires_at        DateTime
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  platform_admin PlatformAdmin? @relation(fields: [platform_admin_id], references: [id], onDelete: Cascade)

  @@index([platform_admin_id])
}

model PlatformAdminApprovalRequest {
  id                String   @id @default(uuid())
  platform_admin_id String
  session_id        String?
  status            String   @default("pending")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  platform_admin PlatformAdmin @relation(fields: [platform_admin_id], references: [id], onDelete: Cascade)

  @@index([platform_admin_id])
  @@index([status])
}

model InstitutionAdmin {
  id                         String    @id @default(uuid())
  full_name                  String
  date_of_birth              DateTime
  primary_email              String    @unique
  primary_phone              String    @unique
  alternative_email          String?
  alternative_phone          String?
  password_hash              String
  user_id                    String?   @unique
  totp_secret                String?
  recovery_code_hash         String?
  onboarding_completed       Boolean   @default(false)
  is_active                  Boolean   @default(true)
  is_locked                  Boolean   @default(false)
  lock_expires_at            DateTime?
  failed_primary_otp         Int       @default(0)
  failed_alt_otp             Int       @default(0)
  magic_link_token_hash      String?
  magic_link_expires_at      DateTime?
  created_by_platform_admin  String?
  signin_log                 Json      @default("[]")
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  sessions          InstitutionAdminSession[]
  signin_sessions   InstitutionAdminSigninSession[]
  approval_requests InstitutionAdminApprovalRequest[]
}

model InstitutionAdminSession {
  id                   String   @id @default(uuid())
  institution_admin_id String
  refresh_token        String   @unique
  access_token         String?
  expires_at           DateTime
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  institution_admin InstitutionAdmin @relation(fields: [institution_admin_id], references: [id], onDelete: Cascade)

  @@index([institution_admin_id])
}

model InstitutionAdminSigninSession {
  id                   String   @id @default(uuid())
  session_id           String   @unique
  institution_admin_id String?
  password_verified    Boolean  @default(false)
  draft_data           Json     @default("{}")
  expires_at           DateTime
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  institution_admin InstitutionAdmin? @relation(fields: [institution_admin_id], references: [id], onDelete: Cascade)

  @@index([institution_admin_id])
}

model InstitutionAdminApprovalRequest {
  id                   String   @id @default(uuid())
  institution_admin_id String
  session_id           String?
  status               String   @default("pending")
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  institution_admin InstitutionAdmin @relation(fields: [institution_admin_id], references: [id], onDelete: Cascade)

  @@index([institution_admin_id])
  @@index([status])
}

enum LxpMemberRole {
  coordinator
  faculty
  student
}

model LxpMember {
  id                    String        @id @default(uuid())
  role                  LxpMemberRole
  full_name             String
  email                 String
  phone                 String?
  department            String?
  employee_id           String?
  extra_data            Json          @default("{}")
  password_hash         String
  user_id               String?       @unique
  must_change_password  Boolean       @default(true)
  onboarding_completed  Boolean       @default(false)
  totp_secret           String?
  recovery_code_hash    String?
  magic_link_token_hash String?
  magic_link_expires_at DateTime?
  created_by_type       String?
  created_by_id         String?
  is_active             Boolean       @default(true)
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  sessions           LxpMemberSession[]
  signin_sessions    LxpMemberSigninSession[]
  approval_requests  LxpMemberApprovalRequest[]
  bulk_upload_credentials MemberBulkUploadCredential[]

  @@unique([email, role])
  @@index([role])
  @@index([created_by_id])
}

model LxpMemberSession {
  id              String   @id @default(uuid())
  member_id       String
  refresh_token   String   @unique
  expires_at      DateTime
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  member LxpMember @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id])
}

model LxpMemberSigninSession {
  id              String   @id @default(uuid())
  session_id      String   @unique
  member_id       String
  password_verified Boolean @default(false)
  draft_data      Json     @default("{}")
  expires_at      DateTime
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  member LxpMember @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id])
}

model LxpMemberApprovalRequest {
  id            String   @id @default(uuid())
  member_id     String
  session_id    String?
  approver_role String
  status        String   @default("pending")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  member LxpMember @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id])
  @@index([status])
  @@index([approver_role])
}

model MemberBulkUpload {
  id               String        @id @default(uuid())
  role             LxpMemberRole
  uploaded_by_type String
  uploaded_by_id   String?
  tenant_id        String?
  tenant_name      String?
  file_name        String?
  total_rows       Int           @default(0)
  succeeded        Int           @default(0)
  failed           Int           @default(0)
  created_at       DateTime      @default(now())

  credentials MemberBulkUploadCredential[]

  @@index([uploaded_by_type])
  @@index([created_at])
}

model MemberBulkUploadCredential {
  id             String   @id @default(uuid())
  bulk_upload_id String
  member_id      String?
  row_index      Int
  full_name      String
  email          String
  user_id        String?
  temp_password  String
  magic_link     String
  email_sent     Boolean  @default(true)
  created_at     DateTime @default(now())

  bulk_upload MemberBulkUpload @relation(fields: [bulk_upload_id], references: [id], onDelete: Cascade)
  member      LxpMember?       @relation(fields: [member_id], references: [id], onDelete: SetNull)

  @@index([bulk_upload_id])
  @@index([email])
}

model Tenant {
  id                            String   @id @default(uuid())
  tenant_id                     String   @unique
  tenant_name                   String
  tenant_type                   String
  country                       String
  state                         String
  city                          String
  contact_person_name           String
  contact_email                 String
  contact_mobile                String
  alternate_contact_person_name String?
  alternate_contact_email       String?
  alternate_contact_mobile      String?
  platform_purpose              String
  programme_category            String
  programmes_offered            String
  expected_users                String
  subscription_plan             String
  status                        String   @default("ACTIVE")
  created_by_type               String?
  created_by_id                   String?
  created_at                    DateTime @default(now())
  updated_at                    DateTime @updatedAt

  module_configuration TenantModuleConfiguration?

  @@index([tenant_type])
  @@index([status])
}

model TenantModuleConfiguration {
  id                     String   @id @default(uuid())
  tenant_id              String   @unique
  profiling_tenant_types Json     @default("[]")
  selected_modules       Json     @default("[]")
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
}
